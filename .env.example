# Режим запуска: development (Flask dev-сервер) или production (Waitress WSGI).
APP_ENV=development

# Секрет для подписи JWT-токенов.
# Замените на произвольную длинную случайную строку перед запуском в продакшене.
JWT_SECRET_KEY=change-me-to-a-strong-random-secret

# Путь к файлу базы данных SQLite.
DB_PATH=db.sqlite

# Порт, на котором будет запущен сервер.
PORT=5000